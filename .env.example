# ──────────────────────────────────────────────
#  KeaBuilder ML Service — Environment Variables
# ──────────────────────────────────────────────

# Service
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# Active model: student | minilm | teacher
ACTIVE_MODEL=student

# Redis (Feature flags + Celery broker)
REDIS_URL=redis://localhost:6379/0

# Qdrant vector DB
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=keabuilder_leads

# Model paths
STUDENT_MODEL_PATH=distillation/artifacts/student_model.pt
TEACHER_MODEL_NAME=all-mpnet-base-v2
MINILM_MODEL_NAME=all-MiniLM-L6-v2

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
